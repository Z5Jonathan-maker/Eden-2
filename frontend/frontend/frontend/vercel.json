{
  "version": 2,
  "buildCommand": "cd frontend && npm run build && ls -la build/ && cp -r build/. ../build/ && ls -la ../build/",
  "outputDirectory": "build",
  "framework": null,
  "installCommand": "cd frontend && npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://eden-2.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://eden-2.onrender.com/health"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://eden-2.onrender.com/ws/:path*"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
