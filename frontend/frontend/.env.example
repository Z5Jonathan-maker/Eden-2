# Eden Frontend Environment Configuration
# Copy this file to .env and fill in the values

# REQUIRED: Backend API URL (must be accessible from frontend)
REACT_APP_BACKEND_URL=http://localhost:8000

# OPTIONAL: Legacy alias for backend URL (REACT_APP_BACKEND_URL takes precedence)
# REACT_APP_API_URL=http://localhost:8000

# OPTIONAL: Base URL for contract/pdf assets (default: /assets/contracts)
REACT_APP_ASSET_BASE_URL=/assets/contracts

# OPTIONAL: Base URL for images used by card templates (default: /images)
REACT_APP_IMAGE_BASE_URL=/images

# OPTIONAL: Config version label shown in OpsConfigBanner
REACT_APP_CONFIG_VERSION=2026-LOCAL

# OPTIONAL: Offline queue feature flag (default: enabled)
REACT_APP_ENABLE_OFFLINE_QUEUE=true

# OPTIONAL: Google Maps API key (required for Harvest map features)
# Get yours at https://console.cloud.google.com/apis/credentials
# Vite exposes env vars prefixed with VITE_ — set either or both:
VITE_GOOGLE_MAPS_API_KEY=
REACT_APP_GOOGLE_MAPS_API_KEY=

# OPTIONAL: Property assignment template ID
REACT_APP_PA_TEMPLATE_ID=care-claims-pa-agreement

# OPTIONAL: Sentry error tracking (production only)
# Get your DSN from https://sentry.io
REACT_APP_SENTRY_DSN=
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=0.1.0
